extends ./layout/index
block contenido 
    //pre= JSON.stringify(paginaActual, undefined, 2)
        //- h1.text-4xl.my-10.font-extrabold.text-center Isi 
        //-     span.font-normal Office
    //- div(class="flex flex-wrap gap-4 justify-center")
